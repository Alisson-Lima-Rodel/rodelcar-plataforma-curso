# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=rodelcar
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=rodelcar

# ── Backend ───────────────────────────────────────────────────────────────────
# DATABASE_URL é montada automaticamente no docker-compose a partir das vars acima.
# Defina manualmente apenas para rodar o backend fora do Docker:
# DATABASE_URL=postgresql+asyncpg://rodelcar:change-me@localhost:5432/rodelcar

JWT_SECRET=change-this-to-a-strong-random-secret-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=30

# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
RODELCAR_FERNET_KEY=

# Segredo para chamadas internas (POST /internal/notificacoes/processar)
INTERNAL_TOKEN=change-to-a-strong-random-secret

ENVIRONMENT=development

RATE_LIMIT_PUBLIC=100/minute
CORS_ORIGINS=http://localhost:3000
# Anti brute-force em login/refresh (formato slowapi)
RATE_LIMIT_AUTH=5/minute
# Rate limit compartilhado entre instâncias (PRODUÇÃO multi-instância). Vazio = memória.
RATELIMIT_STORAGE_URI=

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# E-mail
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASSWORD=re_xxxx
EMAIL_FROM=noreply@rodelcar.com.br

# WhatsApp — escolha um provider
WA_PROVIDER=meta
WA_META_TOKEN=EAAxxxx
WA_META_PHONE_ID=1234567890
WA_META_APP_SECRET=segredo_do_app_meta
WA_META_VERIFY_TOKEN=qualquer_string_secreta

RENOVACAO_URL=https://rodelcar.com.br
